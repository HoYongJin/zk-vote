# ===========================================================================
# Root .env - used by local Rust backend runs, local chain checks, and GCP
# deploy/setup scripts. This file must remain valid POSIX-ish shell: several
# scripts load it with `source .env`.
#
# The localhost values below are LOCAL DEFAULTS ONLY. Production Cloud Run does
# not read this file at runtime; it receives DATABASE_URL, REDIS_URL,
# SEPOLIA_RPC_URL, OWNER_PRIVATE_KEY, RELAYER_PRIVATE_KEY, and ARTIFACT_BUCKET
# from Secret Manager via scripts/cicd/deploy-production-api.sh.
#
# Do not put raw <PLACEHOLDER> values in assignments. Use blank values or
# comment out the key until you fill it.
#
# The vendored migration env (scripts/migration/.env, gitignored) owns
# Supabase data-store credentials.
# Canonical local/staging/prod setup decisions: docs/SETUP_DECISIONS.md.
# ===========================================================================

# --- Local Rust API defaults (crates/api) ---
APP_ENV=local
APP_BIND_ADDR=127.0.0.1:8080

DATABASE_URL=postgres://zkvote:zkvote_dev_password@localhost:5432/zkvote
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1

ARTIFACT_STORE=local
ARTIFACT_LOCAL_DIR=.data/zk-artifacts
ARTIFACT_BUCKET=
CONTRACT_ARTIFACTS_DIR=out

# Cloud project selection. Keep this blank in the shared .env unless you are
# intentionally targeting exactly one environment from this checkout.
#
# Staging:    GCP_PROJECT_ID=zkvote-staging-hhyyj
# Production: GCP_PROJECT_ID=zkvote-prod-hhyyj
#
# The value must equal the GCIP/Firebase project id, JWT audience, and
# frontend VITE_FIREBASE_PROJECT_ID for the same environment.
GCP_PROJECT_ID=
GCP_PROJECT_ID_FALLBACK=
GCP_REGION=asia-northeast3

# --- Auth: GCP Identity Platform (GCIP) / Firebase ID tokens ---
# The frontend mints Firebase/GCIP ID tokens, so set the GCIP values explicitly.
# JWKS = the fixed Google securetoken JWK endpoint (NOT the /robot x509 PEM one).
AUTH_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
# Issuer + audience MUST be set explicitly for GCIP in any non-local deploy.
# Fill with the exact Firebase/GCIP project id. If GCP_PROJECT_ID is set above
# and this file is sourced by shell, the examples below expand correctly.
#JWT_ISSUER=https://securetoken.google.com/${GCP_PROJECT_ID}
#JWT_AUDIENCE=${GCP_PROJECT_ID}
# Deprecated runtime aliases accepted by the Rust API for rollback only. Prefer
# AUTH_JWKS_URL/JWT_ISSUER/JWT_AUDIENCE in new config.
#SUPABASE_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
#SUPABASE_JWT_ISSUER=https://securetoken.google.com/${GCP_PROJECT_ID}
#SUPABASE_JWT_AUDIENCE=${GCP_PROJECT_ID}
# Data-plane URL — used by migration/import tooling only;
# NOT used for auth once the explicit GCIP issuer above is set.
SUPABASE_URL=

# --- Chain / Foundry / Rust relayer ---
SEPOLIA_RPC_URL=
CHAIN_ID=11155111
# Legacy fallback accepted by config.rs; prefer RELAYER_PRIVATE_KEY.
PRIVATE_KEY=
# AR-M4 key separation: the VotingTally owner (configureElection rights) MUST
# differ from the hot relayer key in staging/production.
OWNER_PRIVATE_KEY=
# Rust-side name for the same relayer key (staging Secret Manager parity).
RELAYER_PRIVATE_KEY=

# --- Contract source verification (Etherscan) ---
# Used by scripts/verify/verify-*-contracts-etherscan.ts after Rust/alloy
# deployment. This does NOT authorize deployment and is not read by the API
# runtime unless a future backend verifier is explicitly added.
ETHERSCAN_API_KEY=
ETHERSCAN_CHAIN=sepolia
ETHERSCAN_VERIFY_AFTER_DEPLOY=true

# Production setup prefers fresh production-only key names. If these are blank,
# scripts/iac/zkvote-production-setup.sh generates fresh keys into Secret
# Manager. To intentionally reuse OWNER_PRIVATE_KEY/RELAYER_PRIVATE_KEY for a
# non-production rehearsal, set ALLOW_NONFRESH_PROD_KEYS=yes explicitly.
PROD_OWNER_PRIVATE_KEY=
PROD_RELAYER_PRIVATE_KEY=
ALLOW_NONFRESH_PROD_KEYS=no

# --- GCP/Firebase production bootstrap knobs ---
# Leave CONFIRM_COSTS blank by default. Set it only on the command invocation
# that is supposed to create or mutate billable cloud resources.
CONFIRM_COSTS=
FIREBASE_LOCATION_ID=asia-northeast3
FIREBASE_SITE_ID=
FIREBASE_DEPLOY_SERVICE_ACCOUNT=
GOOGLE_CLOUD_QUOTA_PROJECT=
MIN_INSTANCES=
MAX_INSTANCES=

# NOTE: SECRET_SALT was removed (audit H2 / AR-L5). The server no longer
# derives voter secrets; clients generate and keep their own secret.
