# ===========================================================================
# Root .env — used by the Rust backend (rust-backend/), Foundry/local chain
# checks, and GCP deploy scripts. The vendored migration env
# (scripts/migration/.env, gitignored) owns Supabase data-store credentials.
# Canonical local/staging/prod setup decisions: docs/SETUP_DECISIONS.md.
# ===========================================================================

# --- Rust API (crates/api) ---
APP_ENV=local
APP_BIND_ADDR=127.0.0.1:8080

DATABASE_URL=postgres://zkvote:zkvote_dev_password@localhost:5432/zkvote
REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TLS=false

ARTIFACT_STORE=local
ARTIFACT_LOCAL_DIR=.data/zk-artifacts
ARTIFACT_BUCKET=zkvote-staging-artifacts-zkvote-staging-hhyyj
CONTRACT_ARTIFACTS_DIR=out

# Dedicated staging project. Must equal the GCIP project, the JWT audience, and
# VITE_FIREBASE_PROJECT_ID.
GCP_PROJECT_ID=zkvote-staging-hhyyj
GCP_REGION=asia-northeast3

# --- Auth: GCP Identity Platform (GCIP) / Firebase ID tokens ---
# The frontend mints Firebase/GCIP ID tokens, so set the GCIP values explicitly.
# JWKS = the fixed Google securetoken JWK endpoint (NOT the /robot x509 PEM one).
AUTH_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
# Issuer + audience MUST be set explicitly for GCIP. <PROJECT_ID> is the
# GCIP/Firebase project id and MUST equal VITE_FIREBASE_PROJECT_ID and the Cloud
# Run PROJECT_ID.
JWT_ISSUER=https://securetoken.google.com/<PROJECT_ID>
JWT_AUDIENCE=<PROJECT_ID>
# Deprecated runtime aliases accepted by the Rust API for rollback only. Prefer
# AUTH_JWKS_URL/JWT_ISSUER/JWT_AUDIENCE in new config.
#SUPABASE_JWKS_URL=https://www.googleapis.com/service_accounts/v1/jwk/securetoken@system.gserviceaccount.com
#SUPABASE_JWT_ISSUER=https://securetoken.google.com/<PROJECT_ID>
#SUPABASE_JWT_AUDIENCE=<PROJECT_ID>
# Data-plane URL — used by migration/import tooling only;
# NOT used for auth once the explicit GCIP issuer above is set.
SUPABASE_URL=replace-me

# --- Chain / Foundry / Rust relayer ---
SEPOLIA_RPC_URL=replace-me
CHAIN_ID=11155111
# Legacy fallback accepted by config.rs; prefer RELAYER_PRIVATE_KEY.
PRIVATE_KEY=replace-me
# AR-M4 key separation: the VotingTally owner (configureElection rights).
# MUST differ from the hot relayer key in staging/production.
#OWNER_ADDRESS=
#OWNER_PRIVATE_KEY=
# Rust-side name for the same relayer key (staging Secret Manager parity).
RELAYER_PRIVATE_KEY=replace-me
# Optional: explorer/source verification tooling, if used.
ETHERSCAN_API_KEY=replace-me

# NOTE: SECRET_SALT was removed (audit H2 / AR-L5). The server no longer
# derives voter secrets; clients generate and keep their own secret.
