{
  "name": "zk-vote",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "verify:artifacts": "bash scripts/verify/check-artifact-schema.sh",
    "verify:staging": "bash scripts/verify/verify-staging.sh",
    "verify:staging:chain": "node --import tsx scripts/verify/check-staging-chain.ts",
    "verify:staging:e2e": "node --import tsx scripts/verify/e2e-staging.ts",
    "verify:staging:browser": "node --import tsx scripts/verify/browser-smoke-staging.ts",
    "verify:staging:reconcile": "node --import tsx scripts/verify/reconcile-staging-tally.ts",
    "verify:staging:load": "node --import tsx scripts/verify/load-staging-readonly.ts"
  },
  "devDependencies": {
    "@ethersproject/keccak256": "^5.8.0",
    "@ethersproject/signing-key": "^5.8.0",
    "@playwright/test": "^1.61.1",
    "@supabase/supabase-js": "^2.49.4",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "circomlib": "2.0.5",
    "circomlibjs": "0.1.7",
    "firebase-admin": "^14.0.0",
    "fixed-merkle-tree": "0.7.3",
    "pg": "8.16.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "snarkjs": "0.7.5"
  }
}
