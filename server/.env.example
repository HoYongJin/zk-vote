# ===========================================================================
# server/.env — the ONLY env file the Node/Express API loads
# (server/supabaseClient.js calls dotenv with this exact path; the repo-root
# .env is for the Rust backend and Hardhat).
# ===========================================================================

# HTTP port for the Express API.
PORT=4000
# Optional: public URL printed at startup (logging only).
DEPLOY_URL=http://localhost:4000

# --- Supabase (hosted) ---
SUPABASE_URL=replace-me
# Service-role key for server-side table access. Falls back to SUPABASE_KEY
# (anon) if unset — set the service-role key explicitly in any real env.
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_KEY=replace-me

# --- Redis (locks, Merkle leaf cache, submission tickets) ---
# Either a single URL (rediss:// implies TLS) ...
REDIS_URL=redis://localhost:6379
# ... or host/port (used when REDIS_URL is unset). REDIS_TLS=true forces TLS.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_TLS=false

# --- Ethereum relayer (vote submission, finalize, deploy) ---
SEPOLIA_RPC_URL=replace-me
# Hot relayer key (vote submission). Holds NO contract-owner rights (AR-M4).
PRIVATE_KEY=replace-me
# Contract owner key used ONLY by finalize (configureElection). Falls back
# to PRIVATE_KEY for single-key local dev.
#OWNER_PRIVATE_KEY=
# AR-H1: refuse to deploy zkeys that were not finalized with a public beacon.
# Set true in staging/production.
REQUIRE_BEACON=false

# --- ZK toolchain ---
# Absolute path to the circom binary if it is not on PATH
# (used by /setZkDeploy preflight and setUpZk.sh).
CIRCOM_BIN=circom

# NOTE: SECRET_SALT was removed (audit H2). The server never derives or
# stores plaintext voter secrets anymore.
