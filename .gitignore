node_modules
*.tsbuildinfo
.env
.env.local

# Service-account / credential material — NEVER commit. The GCIP import script
# (scripts/migration/import-users-to-gcip.js) and the Firebase Hosting CD
# (.github/workflows/deploy-production.yml) uses Workload Identity Federation;
# these patterns ensure a stray local Firebase Admin JSON cannot be staged by a
# stray `git add .` cannot stage a live GCP credential.
*-admin.json
service-account*.json
serviceAccount*.json
*-sa.json
firebase-debug.log
.firebase/
firebase*.generated.json
firebase.*.generated.json

zk/tmp/
zk/input/
zk/circomlib/
zk/build/circuit_0000.zkey
# Per-environment deployment state: binds deployed elections to artifact hashes (audit M5).
zk/artifact-manifest.json
*.ptau
zk-vote-key.pem
build_3
test-proof-generator.js

